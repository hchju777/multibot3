# LocalPlanShare — L4 로봇 간 **채택 계획** 공유 (이웃 LSC 제약의 입력)
#
# 계약 버전: 1.0.0 (신설 — theory T4-R3 / T4 §8-(a) L-15-5·L-15-6)
# 근거: dlsc-2023 가정 3(에이전트는 직전 재계획 스텝의 궤적을 공유), 정리 T4.1 조건 (A1)(A2),
#       정의 T4.1-(3) 발행, 정리 T4.3(이웃 계획 미수신 시 자기 폴백)
# 토픽: /robot_{i}/local_plan_share
# QoS: **best_effort** / volatile / depth 1 / deadline 2*Δt_h
#      reliable 을 쓰지 않는 이유: 재전송된 낡은 계획은 쓸모가 없고(신선도는 tick_seq 로 판정),
#      손실은 안전을 깨지 않는다 — 수신자가 인증 폴백으로 흡수한다(정리 T4.3). 최신성이 우선이다.
#
# ⚠ 신설 사유(정직 고지): L4 이웃 간 궤적 교환은 D-07(분산 MPC·LSC)의 필수 입력인데
#   architecture §1.2 노드 그래프와 계약 v1.x 어디에도 이 토픽이 없었다 — theory T4 가 드러낸
#   **계약 결손**이다. sw-architect 확인 권고(노드 그래프 갱신 필요).
#
# ── 발행 규약 (정의 T4.1-(3), L-15-5·L-15-6) ──────────────────────────────────────────
#  1. **매 틱 발행한다.** QP 를 풀었든 인증 폴백했든 예외 없다. 발행이 빠지면 이웃은 신선도
#     결손으로 판단해 동반 감속한다(불필요한 처리량 손실).
#  2. 발행 대상은 **스텝 h 의 채택 계획 c^(h)** 다. 시프트 결과 c_hat 을 발행하지 말 것 —
#     수신자가 스스로 S 를 적용하는 구조이므로 c_hat 을 보내면 **한 스텝 어긋난다**(T4 §2 관찰 3).
#     인증 폴백 시에는 c^(h) = c_hat^(h) 이므로 결과적으로 시프트된 계획이 실리지만,
#     그것은 "채택 계획을 보낸다"는 규칙의 결과이지 예외가 아니다.
#  3. `tick_seq` 는 **필수**다. 이것이 (A1) 지수 합의를 피기백으로 달성하는 수단이며,
#     수신자는 틱 메시지를 놓쳐도 이 값에서 h 를 복원할 수 있다(T4 §6).
#
# ── 수신자 규약 ───────────────────────────────────────────────────────────────────────
#  * 스텝 h 에서 QP 를 풀려면 모든 이웃 j 의 `tick_seq = h-1` 메시지를 보유해야 한다
#    (fresh_j(h-1)). 하나라도 없으면 **QP 금지, 인증 폴백 강제**(정리 T4.3).
#  * 수신 계획에 S 를 적용해 c_hat_j^(h) 를 국소 유도한다. 이웃의 스텝 h 행동을 예측하지
#    않으며, 예측할 필요도 없다 — 안전은 양측이 같은 반평면 쌍을 계산하고 각자 자기 쪽을
#    지킴으로써 성립한다(T4 §2 관찰 1).
#  * `shift_ratio_u` 가 자기 값과 다르면 (A1) 위반이므로 그 이웃의 계획을 **신선하지 않은 것으로
#    취급**하고(= 폴백) 로그한다. 무시하고 QP 를 풀지 말 것.
#
# ⚠ 이 메시지는 "QP 채택"과 "인증 폴백"을 **구별해 싣지 않는다**. 안전에 불필요하기 때문이다
#   (정리 T4.1 은 네 조합 모두를 덮는다). 관측은 서버 측 CommitStatus.qp_status 로 한다.
#   이웃이 "폴백 중"과 "고장"을 구별하지 못하는 문제는 **미결 O-T4-3**(하트비트 분리 권고)이며,
#   이 계약은 그것을 해결하지 않는다.

std_msgs/Header header       # stamp = 발행 시각(sim clock), frame_id = "map"
uint16 robot_id
uint32 tick_seq              # 이 계획의 스텝 지수 h. **필수** — (A1) 합의·신선도 판정의 키

uint8 num_segments           # 지평 세그먼트 수 H (T1 §6.1 기본 4)
uint8 bernstein_degree       # Bernstein 차수 n (T1 §6.1 기본 5)
float64[] control_points     # 채택 계획 c^(h) 의 **오프셋점 z** 제어점 [m], map 프레임.
                             # 평탄 배열 (x,y) 순, 길이 = 2*num_segments*(bernstein_degree+1),
                             # 순서 = 세그먼트 m 오름차순 → 제어점 k 오름차순
float64 segment_duration_s   # 세그먼트 길이 Δt [s] (T1 기본 0.5)
float64 shift_ratio_u        # u = Δt_h/Δt. 수신자는 자기 값과 일치할 때만 이 계획을 신뢰한다((A1))
