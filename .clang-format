# .clang-format — multibot3 C++ 코딩 규율의 기계 강제 (CLAUDE.md 코드 작성 규율 5~6)
#
# 핵심: Allman 스타일(여는 중괄호는 항상 새 줄 — 함수·클래스·if/else/for/while/namespace
# 예외 없이) + PascalCase 타입 / snake_case 함수·변수 / trailing '_' 멤버변수 / UPPER_SNAKE 상수.
# clang-format 은 개행·들여쓰기·중괄호 배치만 강제한다 — 명명 규칙(PascalCase 등)은
# clang-format 의 책임 범위 밖이라 코드 리뷰(reviewer 에이전트)가 별도로 확인한다.
#
# 적용: clang-format -i <file>  (또는 에디터 저장 시 자동 적용 — .vscode/settings.json 참조)
# 검증: clang-format --dry-run --Werror <file>

BasedOnStyle: LLVM
Language: Cpp
Standard: c++17

# ── Allman: 모든 중괄호를 새 줄에 (CLAUDE.md 규율 5 — 예외 없이) ──────────────────────────
BreakBeforeBraces: Allman

# 짧은 블록도 한 줄로 접지 않는다 — Allman 의 "여는 중괄호는 항상 새 줄"을
# if/함수/람다에서도 예외 없이 지키기 위함.
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false
AllowShortBlocksOnASingleLine: Never
AllowShortLambdasOnASingleLine: Empty

# ── 들여쓰기·폭 ───────────────────────────────────────────────────────────────────────
IndentWidth: 2
TabWidth: 2
UseTab: Never
ColumnLimit: 100
AccessModifierOffset: -2
NamespaceIndentation: None
IndentCaseLabels: true
ContinuationIndentWidth: 2

# ── 포인터·참조 정렬 ──────────────────────────────────────────────────────────────────
# `Type & name` / `Type * name` (양쪽 공백). 근거 2가지:
#  1. **잠긴 계약 포트 헤더 9종이 전부 이 스타일**이다. Left(`Type& name`)로 두면 계약 파일을
#     재포맷해야 하는데 그것들은 잠겨 있다.
#  2. ROS 2 코어·ament 관례가 이것이다(`const std::string & name`).
# ⚠ 이 값은 원래 Left 였고, 그때는 clang-format 바이너리가 없어 **검증되지 않은 채** 들어갔다.
#    2026-07-21 실측에서 108파일 중 101파일이 위반으로 잡혔고 원인의 대부분(&  1069건, * 182건)이
#    이 항목이었다. 설정이 아니라 코드가 정본이라고 판정해 설정을 코드에 맞췄다.
PointerAlignment: Middle
ReferenceAlignment: Middle

# ── 정렬·줄바꿈 ───────────────────────────────────────────────────────────────────────
# 인자가 한 줄에 안 들어가면 여는 괄호 **뒤에서 줄을 바꾸고 2칸 들여쓴다**(ContinuationIndentWidth).
# 여는 괄호 위치에 정렬(Align)하지 않는 이유: 함수명이 길면 우측 여백이 없어져 다시 접히고,
# 이름을 바꾸면 무관한 줄들이 전부 재정렬된다. ROS 2 코어 관례이자 이 코드베이스의 실제 스타일이다.
AlignAfterOpenBracket: AlwaysBreak
# 반환형을 홀로 줄에 두는 것보다 인자를 접는 쪽을 강하게 선호한다 — `bool\nfoo(...)` 는
# 이 코드베이스에 한 건도 없다.
PenaltyReturnTypeOnItsOwnLine: 1000
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignOperands: Align
AlignTrailingComments: true
BinPackArguments: true
BinPackParameters: true
BreakConstructorInitializers: BeforeColon
ConstructorInitializerAllOnOneLineOrOnePerLine: false
Cpp11BracedListStyle: true
SpaceBeforeParens: ControlStatements
SpacesInAngles: false
SortIncludes: CaseSensitive
IncludeBlocks: Preserve

# ── 예외 규율 지원(CLAUDE.md 규율 2) — try/catch 도 Allman 로 감싸진다(위 옵션이 이미 강제) ──
SpaceAfterCStyleCast: false
DerivePointerAlignment: false
