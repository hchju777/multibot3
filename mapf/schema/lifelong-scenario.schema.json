{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MAPF Lifelong Scenario",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "map": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "string",
      "minLength": 1
    },
    "robots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "type": "integer"
          },
          "home": {
            "type": "integer"
          }
        },
        "required": ["id", "start"]
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replan_policy": {
          "type": "string",
          "enum": ["replan_on_assignment"]
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": ["assign_goal"]
              },
              "robot": {
                "type": "string",
                "minLength": 1
              },
              "goal": {
                "type": "integer"
              },
              "when": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["at_start", "after_initial", "on_robot_idle"]
                  },
                  "robot": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["type"]
              },
              "after": {
                "oneOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                ]
              }
            },
            "required": ["id", "type", "robot", "goal", "when"]
          }
        }
      },
      "required": ["replan_policy", "events"]
    }
  },
  "required": ["map", "params", "robots", "scenario"]
}
