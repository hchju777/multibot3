<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>mrs_ros_sadg</name>
  <version>0.1.0</version>
  <description>sadg_service — L3 릴리스 경로의 심장 (D-04, D-05, D-06). btpg/milp/judge/릴리스를 한 프로세스에 둔다(architecture §1.1 통합 근거). 콜백 안에 알고리즘 없음 — 전부 도메인 패키지 위임.</description>
  <maintainer email="hchju23257@gmail.com">Changju Hwang</maintainer>
  <license>TBD</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <depend>rclcpp</depend>
  <depend>mrs_interfaces</depend>
  <depend>mrs_msg_convert</depend>
  <depend>mrs_depgraph</depend>
  <depend>mrs_reorder_btpg</depend>
  <depend>mrs_reorder_milp</depend>
  <depend>mrs_judge</depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
